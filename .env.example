PUBLIC_API_URL=http://localhost:3001
PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-public-key-here
PUBLIC_SITE_URL=https://devboards.io
# Microsoft Clarity project ID for session recordings & heatmaps (cookieless analytics).
# In staging/prod this is injected at Docker build time via GitHub Secrets:
#   VITE_CLARITY_ID_STAGING -> secrets.VITE_CLARITY_ID_STAGING
#   VITE_CLARITY_ID_PROD    -> secrets.VITE_CLARITY_ID_PROD
# For local dev you can paste your Clarity project ID here or leave it empty.
VITE_CLARITY_ID=XXXXXXXXX